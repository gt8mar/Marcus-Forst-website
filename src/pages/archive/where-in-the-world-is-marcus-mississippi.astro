<script>
  const scene = document.querySelector('.pixel-scene');

  const toParts = (date) =>
    new Intl.DateTimeFormat('en-US', {
      timeZone: 'America/Chicago',
      hour12: false,
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit'
    }).formatToParts(date);

  const clockSeconds = () => {
    const parts = toParts(new Date());
    const get = (type) => Number(parts.find((p) => p.type === type)?.value || 0);
    return get('hour') * 3600 + get('minute') * 60 + get('second');
  };

  const updateSky = () => {
    if (!scene) return;
    const seconds = clockSeconds();
    const dayStart = 6 * 3600;
    const dayEnd = 18 * 3600;
    const isDay = seconds >= dayStart && seconds < dayEnd;
    scene.classList.toggle('is-night', !isDay);

    if (isDay) {
      const progress = (seconds - dayStart) / (dayEnd - dayStart);
      const sunX = 72 + 14 * progress;
      const sunY = 16 - 8 * Math.sin(progress * Math.PI);
      scene.style.setProperty('--sun-x', `${sunX}%`);
      scene.style.setProperty('--sun-y', `${sunY}%`);
      return;
    }

    const nightSeconds = seconds >= dayEnd ? seconds - dayEnd : seconds + 6 * 3600;
    const nightProgress = nightSeconds / (12 * 3600);
    const moonX = 16 + 24 * nightProgress;
    const moonY = 72 - 30 * nightProgress;
    scene.style.setProperty('--moon-x', `${moonX}%`);
    scene.style.setProperty('--moon-y', `${moonY}%`);
  };

  updateSky();
  setInterval(updateSky, 60 * 1000);
</script>
