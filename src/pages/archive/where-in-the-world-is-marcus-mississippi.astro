---
import Layout from '../../components/layout.astro';
---

<Layout
  title="Where In The World Is Marcus (Archive: Mississippi)"
  description="Archived location snapshot from Columbus, Mississippi."
  currentPath="/where-in-the-world-is-marcus"
>
  <main class="pixel-page">
    <h1>Where in the world is Marcus?</h1>
    <p class="location" aria-label="Archived location">Columbus, Mississippi</p>
    <p class="tagline">Pixel steamboat report from the Tombigbee</p>
    <div class="pixel-scene" aria-hidden="true">
      <div class="pixel-sun"></div>
      <div class="pixel-moon"></div>
      <div class="pixel-city"></div>
      <div class="riverfront-strip">
        <div class="shop shop-jb">
          <span class="shop-sign">J. Broussard's</span>
          <span class="window-grid"></span>
        </div>
        <div class="shop shop-arepas">
          <span class="shop-sign">Arepas Coffee + Bar</span>
          <span class="window-grid"></span>
        </div>
        <div class="shop shop-harveys">
          <span class="shop-sign">Harvey's</span>
          <span class="window-grid"></span>
        </div>
        <div class="shop shop-munson">
          <span class="shop-sign">Munson &amp; Brothers Pizza</span>
          <span class="window-grid"></span>
        </div>
      </div>
      <div class="street-band"></div>
      <div class="grass-band"></div>
      <div class="pixel-plane" aria-hidden="true">
        <span class="plane-tail"></span>
        <span class="plane-wing"></span>
        <span class="prop"></span>
      </div>
      <div class="tree-line">
        <div class="tree tree-1"></div>
        <div class="tree tree-2"></div>
        <div class="tree tree-3"></div>
        <div class="tree tree-4"></div>
        <div class="tree tree-5"></div>
      </div>
      <div class="riverwalk-path"></div>
      <div class="pixel-cat" aria-hidden="true">
        <span class="cat-leg leg-1"></span>
        <span class="cat-leg leg-2"></span>
        <span class="cat-leg leg-3"></span>
        <span class="cat-leg leg-4"></span>
        <span class="cat-head">
          <span class="ear ear-left"></span>
          <span class="ear ear-right"></span>
          <span class="cat-face"></span>
          <span class="cat-mouth"></span>
        </span>
        <span class="cat-tail"></span>
      </div>
      <div class="pixel-river">
        <div class="boat">
          <span class="smoke smoke-1"></span>
          <span class="smoke smoke-2"></span>
          <span class="smoke smoke-3"></span>
          <span class="wheel"></span>
        </div>
        <div class="sparkle sparkle-1"></div>
        <div class="sparkle sparkle-2"></div>
        <div class="sparkle sparkle-3"></div>
      </div>
    </div>
    <p class="back-home">
      <a href="/">Take me back home</a>
    </p>
    <p class="archive-link">
      <a href="/archive/where-in-the-world-is-marcus-oklahoma">View Oklahoma archive</a>
    </p>
  </main>
</Layout>

<style>
  .pixel-page {
    --ink: #f6f7ff;
    --sky-top: #ffb45f;
    --sky-mid: #f06b6b;
    --sky-bottom: #61458f;
    --river-dark: #12345b;
    --river-mid: #1b4f7e;
    --river-light: #3d9ad1;
    --pixel-shadow: #1a1233;
    width: 100%;
    min-height: calc(100vh - 3.5rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1rem;
    padding: 2rem 1rem 5rem;
    background: linear-gradient(
      180deg,
      var(--sky-top) 0%,
      var(--sky-mid) 38%,
      var(--sky-bottom) 62%,
      #11102d 100%
    );
    color: var(--ink);
    font-family: 'Courier New', Courier, monospace;
    image-rendering: pixelated;
  }

  .pixel-page h1 {
    margin: 0;
    font-size: clamp(1.3rem, 3.2vw, 2.2rem);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-shadow: 3px 3px 0 var(--pixel-shadow);
  }

  .location {
    margin: 0;
    font-size: clamp(1.9rem, 6.5vw, 3.8rem);
    font-weight: 700;
    color: #84f8ff;
    text-shadow: 4px 4px 0 #18355e;
    line-height: 1.08;
  }

  .tagline {
    margin: 0;
    font-size: clamp(0.85rem, 2vw, 1rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #ffe8b3;
  }

  .pixel-scene {
    --sun-x: 82%;
    --sun-y: 12%;
    --moon-x: 14%;
    --moon-y: 68%;
    width: min(92vw, 760px);
    aspect-ratio: 16 / 10.5;
    border: 5px solid #0d0e2e;
    box-shadow:
      0 0 0 5px #f8d65a,
      10px 10px 0 #0d0e2e;
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(
        180deg,
        rgba(255, 201, 109, 0.7) 0%,
        rgba(240, 107, 107, 0.4) 40%,
        rgba(14, 24, 61, 0) 64%
      ),
      repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.03) 0 4px, transparent 4px 8px),
      linear-gradient(180deg, #8a5f85 0%, #402f69 64%, #111832 100%);
  }

  .pixel-sun {
    position: absolute;
    top: var(--sun-y);
    left: var(--sun-x);
    width: 16%;
    aspect-ratio: 1;
    background: #ffef95;
    box-shadow:
      0 0 0 6px #ff9a64,
      0 0 0 12px rgba(255, 154, 100, 0.45);
    animation: pulse-sun 2.8s steps(2, end) infinite;
    transform: translate(-50%, -50%);
    z-index: 1;
  }

  .pixel-moon {
    position: absolute;
    top: var(--moon-y);
    left: var(--moon-x);
    width: 12%;
    aspect-ratio: 1;
    background: #dff3ff;
    box-shadow:
      0 0 0 5px #8ec0e3,
      0 0 0 10px rgba(142, 192, 227, 0.32);
    transform: translate(-50%, -50%);
    opacity: 0;
    z-index: 1;
  }

  .pixel-moon::before {
    content: '';
    position: absolute;
    width: 34%;
    aspect-ratio: 1;
    top: 26%;
    left: 22%;
    background: #acd3eb;
    opacity: 0.8;
  }

  .pixel-moon::after {
    content: '';
    position: absolute;
    width: 20%;
    aspect-ratio: 1;
    top: 56%;
    left: 58%;
    background: #acd3eb;
    opacity: 0.75;
  }

  .pixel-city {
    position: absolute;
    bottom: 36%;
    left: 0;
    width: 100%;
    height: 24%;
    background:
      linear-gradient(90deg, transparent 0 3%, #2f264f 3% 8%, transparent 8% 10%, #201a3f 10% 15%, transparent 15% 18%, #362d5b 18% 23%, transparent 23% 26%, #271f49 26% 33%, transparent 33% 35%, #33295a 35% 40%, transparent 40% 43%, #241d47 43% 48%, transparent 48% 52%, #362d5b 52% 57%, transparent 57% 61%, #251e48 61% 67%, transparent 67% 70%, #2d2452 70% 76%, transparent 76% 80%, #201a3f 80% 86%, transparent 86% 100%);
    box-shadow: 0 -4px 0 #ffcc7a;
  }

  .riverfront-strip {
    position: absolute;
    left: 0;
    bottom: 42%;
    width: 100%;
    height: 27%;
    display: grid;
    grid-template-columns: 1.05fr 1fr 0.95fr 1.1fr;
    gap: 4px;
    padding: 0 8px;
    z-index: 3;
  }

  .shop {
    position: relative;
    align-self: end;
    height: 100%;
    background:
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.06) 0 3px,
        transparent 3px 8px
      ),
      repeating-linear-gradient(
        180deg,
        #875049 0 6px,
        #7a453f 6px 12px
      );
    border: 3px solid #2c1a32;
    box-shadow:
      inset 0 -10px 0 #e5c898,
      inset 0 -22px 0 #6f2e41,
      inset 0 7px 0 #c38f6d,
      0 -4px 0 #2c1a32;
  }

  .shop::before {
    content: '';
    position: absolute;
    left: 6%;
    right: 6%;
    top: 56%;
    height: 14%;
    background:
      repeating-linear-gradient(
        90deg,
        #f2d5a4 0 10px,
        #c88654 10px 20px
      );
    border: 3px solid #2c1a32;
  }

  .shop::after {
    content: '';
    position: absolute;
    left: 20%;
    right: 20%;
    bottom: 0;
    height: 30%;
    background: #533147;
    border-left: 3px solid #2c1a32;
    border-right: 3px solid #2c1a32;
  }

  .shop-sign {
    position: absolute;
    left: 8%;
    right: 8%;
    top: -14px;
    background: #1a1233;
    border: 3px solid #f7d66f;
    color: #ffefbf;
    font-size: clamp(0.46rem, 1vw, 0.6rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0.02em;
    padding: 2px 3px;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    box-shadow: 2px 2px 0 #2c1a32;
  }

  .window-grid {
    position: absolute;
    left: 11%;
    right: 11%;
    top: 18%;
    height: 32%;
    border: 2px solid #2c1a32;
    background:
      linear-gradient(
        90deg,
        #a9d3ef 0 30%,
        #2c1a32 30% 33%,
        #8ab9dc 33% 63%,
        #2c1a32 63% 66%,
        #a9d3ef 66% 100%
      ),
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.32) 0 18%,
        transparent 18% 100%
      );
    box-shadow:
      inset 0 2px 0 rgba(255, 255, 255, 0.3),
      inset 0 -2px 0 rgba(34, 42, 76, 0.65);
  }

  .shop-jb {
    background:
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.06) 0 3px,
        transparent 3px 8px
      ),
      repeating-linear-gradient(
        180deg,
        #8f4f42 0 6px,
        #784133 6px 12px
      );
  }

  .shop-jb .shop-sign {
    border-color: #f6d791;
    color: #fdf2ce;
  }

  .shop-arepas {
    height: 90%;
    background:
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.06) 0 3px,
        transparent 3px 8px
      ),
      repeating-linear-gradient(
        180deg,
        #7f4e5f 0 6px,
        #6b3e4f 6px 12px
      );
  }

  .shop-arepas .shop-sign {
    border-color: #77e3ff;
    color: #dbf8ff;
  }

  .shop-harveys {
    height: 100%;
    background:
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.06) 0 3px,
        transparent 3px 8px
      ),
      repeating-linear-gradient(
        180deg,
        #6e495f 0 6px,
        #5a3a50 6px 12px
      );
  }

  .shop-harveys .shop-sign {
    border-color: #ffb16b;
    color: #ffe0bd;
  }

  .shop-munson {
    height: 96%;
    background:
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.06) 0 3px,
        transparent 3px 8px
      ),
      repeating-linear-gradient(
        180deg,
        #82523e 0 6px,
        #6f4433 6px 12px
      );
  }

  .shop-munson .shop-sign {
    border-color: #ffd66e;
    color: #fff2bf;
  }

  .pixel-river {
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 30%;
    background:
      repeating-linear-gradient(
        180deg,
        var(--river-light) 0 8px,
        var(--river-mid) 8px 16px,
        var(--river-dark) 16px 24px
      );
    overflow: hidden;
  }

  .street-band {
    position: absolute;
    left: 0;
    bottom: 38%;
    width: 100%;
    height: 4%;
    z-index: 2;
    background:
      repeating-linear-gradient(
        90deg,
        #34313a 0 20px,
        #3f3b47 20px 40px
      );
    box-shadow:
      inset 0 3px 0 #7e6d58,
      inset 0 -3px 0 #201c29;
  }

  .grass-band {
    position: absolute;
    left: 0;
    bottom: 34%;
    width: 100%;
    height: 4%;
    z-index: 2;
    background:
      repeating-linear-gradient(
        90deg,
        #4e8f4a 0 12px,
        #3c7b3f 12px 24px
      );
    box-shadow:
      inset 0 2px 0 rgba(203, 240, 144, 0.45),
      inset 0 -2px 0 #2b5c33;
  }

  .riverwalk-path {
    position: absolute;
    left: 0;
    bottom: 30%;
    width: 100%;
    height: 4%;
    z-index: 2;
    background:
      repeating-linear-gradient(
        90deg,
        #cab08a 0 16px,
        #b69973 16px 32px
      );
    box-shadow:
      inset 0 2px 0 rgba(255, 248, 224, 0.45),
      inset 0 -2px 0 #7d6142;
  }

  .pixel-cat {
    position: absolute;
    right: -12%;
    bottom: 32%;
    width: 8.2%;
    height: 5.6%;
    z-index: 6;
    background:
      repeating-linear-gradient(
        90deg,
        #ffbb5f 0 10px,
        #e98c34 10px 20px
      );
    border: 3px solid #5f2f11;
    border-radius: 6px 6px 10px 10px;
    box-shadow:
      inset 0 -3px 0 #c7681f,
      inset 0 2px 0 #ffd28e;
    animation: cat-walk-rtl 14s linear infinite;
  }

  .pixel-cat::before {
    content: '';
    position: absolute;
    left: 12%;
    right: 12%;
    bottom: -28%;
    height: 34%;
    background:
      repeating-linear-gradient(
        90deg,
        #ffe1b2 0 10px,
        #dc7b26 10px 16px
      );
    border: 3px solid #5f2f11;
    border-radius: 0 0 7px 7px;
  }

  .cat-head {
    position: absolute;
    left: -24%;
    top: -54%;
    width: 46%;
    height: 74%;
    background: #ffb04b;
    border: 3px solid #5f2f11;
    border-radius: 6px;
    animation: cat-look 14s linear infinite;
  }

  .cat-leg {
    position: absolute;
    bottom: -26%;
    width: 12%;
    height: 30%;
    background: #d7721f;
    border: 3px solid #5f2f11;
    border-radius: 4px;
  }

  .leg-1 {
    left: 14%;
    animation: leg-step-a 0.35s steps(2, end) infinite;
  }

  .leg-2 {
    left: 32%;
    animation: leg-step-b 0.35s steps(2, end) infinite;
  }

  .leg-3 {
    left: 56%;
    animation: leg-step-b 0.35s steps(2, end) infinite;
  }

  .leg-4 {
    left: 74%;
    animation: leg-step-a 0.35s steps(2, end) infinite;
  }

  .cat-face {
    position: absolute;
    left: 16%;
    top: 28%;
    width: 68%;
    height: 44%;
    background:
      radial-gradient(circle at 28% 40%, #2e1a12 0 2px, transparent 3px),
      radial-gradient(circle at 72% 40%, #2e1a12 0 2px, transparent 3px),
      radial-gradient(circle at 50% 58%, #c45a56 0 2px, transparent 3px),
      linear-gradient(180deg, transparent 60%, rgba(255, 234, 198, 0.9) 60% 100%);
  }

  .cat-face::before,
  .cat-face::after {
    content: '';
    position: absolute;
    top: 52%;
    width: 42%;
    height: 10%;
    border-top: 2px solid #5f2f11;
    border-bottom: 2px solid #5f2f11;
  }

  .cat-face::before {
    left: -26%;
  }

  .cat-face::after {
    right: -26%;
  }

  .cat-mouth {
    position: absolute;
    left: 34%;
    top: 64%;
    width: 32%;
    height: 24%;
    border-bottom: 3px solid #5f2f11;
    border-left: 3px solid transparent;
    border-right: 3px solid transparent;
    border-radius: 0 0 10px 10px;
  }

  .ear {
    position: absolute;
    top: -38%;
    width: 34%;
    height: 42%;
    background: #ffb04b;
    border: 3px solid #5f2f11;
  }

  .ear-left {
    left: 3%;
  }

  .ear-right {
    right: 3%;
  }

  .cat-tail {
    position: absolute;
    right: -18%;
    top: 8%;
    width: 18%;
    height: 82%;
    background: #d7721f;
    border: 3px solid #5f2f11;
    border-radius: 8px;
    animation: tail-wag 0.9s steps(2, end) infinite;
  }

  .pixel-plane {
    position: absolute;
    left: -16%;
    top: 10%;
    width: 14%;
    height: 6.4%;
    z-index: 5;
    background:
      linear-gradient(180deg, #f7fbff 0 52%, #122c58 52% 100%),
      linear-gradient(90deg, transparent 0 14%, #345b97 14% 86%, transparent 86% 100%);
    border: 3px solid #1d2f47;
    box-shadow: inset 0 -3px 0 #0d2144;
    opacity: 0;
    animation: plane-fly 26s linear infinite;
  }

  .plane-tail {
    position: absolute;
    left: -18%;
    bottom: 8%;
    width: 22%;
    height: 156%;
    border: 3px solid #1d2f47;
    background:
      linear-gradient(180deg, #f7fbff 0 52%, #122c58 52% 100%);
    z-index: -1;
  }

  .plane-tail::before {
    content: '';
    position: absolute;
    right: -74%;
    bottom: 6%;
    width: 74%;
    height: 58%;
    border-top: 3px solid #1d2f47;
    border-right: 3px solid #1d2f47;
    border-bottom: 3px solid #1d2f47;
    border-left: none;
    border-radius: 0 38px 38px 0;
    background:
      linear-gradient(180deg, #f7fbff 0 52%, #122c58 52% 100%);
  }

  .pixel-plane::before {
    content: '';
    position: absolute;
    left: 26%;
    top: -64%;
    width: 46%;
    height: 64%;
    background:
      linear-gradient(90deg, #f9fcff 0 48%, #dbe6f7 48% 100%);
    border: 3px solid #1d2f47;
    border-bottom: none;
    border-radius: 2px 2px 0 0;
  }

  .pixel-plane::after {
    content: '';
    position: absolute;
    left: -12%;
    top: 4%;
    width: 10%;
    height: 64%;
    background:
      linear-gradient(180deg, #f7fbff 0 52%, #122c58 52% 100%);
    border: 3px solid #1d2f47;
  }

  .plane-wing {
    position: absolute;
    left: -1%;
    top: 24%;
    width: 44%;
    height: 56%;
    background:
      linear-gradient(180deg, #f7fbff 0 52%, #122c58 52% 100%);
    border: 3px solid #1d2f47;
    z-index: -1;
    clip-path: polygon(0 50%, 100% 8%, 100% 92%);
  }

  .prop {
    position: absolute;
    right: -18%;
    top: 18%;
    width: 19%;
    height: 68%;
    border: 3px solid #1d2f47;
    background:
      repeating-linear-gradient(90deg, #f4f7fd 0 2px, #9eaec5 2px 4px);
    animation: prop-spin 0.12s linear infinite;
  }

  .prop::before {
    content: '';
    position: absolute;
    left: 24%;
    top: 35%;
    width: 52%;
    height: 30%;
    background: #16366b;
    border: 2px solid #0f2346;
  }

  .pixel-river::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        90deg,
        transparent 0 20px,
        rgba(255, 255, 255, 0.12) 20px 24px,
        transparent 24px 38px
      );
    animation: water-shift 1.8s steps(4, end) infinite;
  }

  .boat {
    position: absolute;
    bottom: 26%;
    left: -22%;
    width: 23%;
    aspect-ratio: 3 / 2;
    background:
      repeating-linear-gradient(
        90deg,
        transparent 0 10px,
        rgba(38, 24, 49, 0.35) 10px 12px
      ),
      linear-gradient(180deg, #f5efda 0 22%, #d8c5a0 22% 48%, transparent 48% 100%),
      linear-gradient(180deg, transparent 0 56%, #8e4f3b 56% 78%, #3d243f 78% 100%);
    box-shadow: 0 0 0 4px #2a123d;
    animation: boat-sail 10s linear infinite;
    z-index: 2;
  }

  .boat::before {
    content: '';
    position: absolute;
    top: -24%;
    left: 14%;
    width: 22%;
    height: 25%;
    background:
      linear-gradient(180deg, #ffdca4 0 26%, #9f5a3c 26% 100%);
    box-shadow:
      0 0 0 3px #2a123d,
      128% 17% 0 0 #ffdca4,
      128% 17% 0 3px #2a123d;
  }

  .boat::after {
    content: '';
    position: absolute;
    right: -8%;
    bottom: 10%;
    width: 12%;
    height: 52%;
    background:
      repeating-linear-gradient(180deg, #f4cf7d 0 5px, #cd7a3f 5px 10px);
    border: 3px solid #2a123d;
  }

  .wheel {
    position: absolute;
    bottom: -14%;
    left: 44%;
    width: 18%;
    aspect-ratio: 1;
    border: 4px solid #2a123d;
    background:
      conic-gradient(from 0deg, #ffe7a1 0 25%, #d85757 25% 50%, #ffe7a1 50% 75%, #d85757 75% 100%);
    animation: wheel-spin 0.9s steps(4, end) infinite;
  }

  .smoke {
    position: absolute;
    top: -34%;
    width: 10%;
    aspect-ratio: 1;
    background: #efe8ff;
    opacity: 0;
    animation: puff 1.7s steps(3, end) infinite;
  }

  .smoke-1 {
    left: 26%;
    animation-delay: 0.2s;
  }

  .smoke-2 {
    left: 42%;
    animation-delay: 0.6s;
  }

  .smoke-3 {
    left: 58%;
    animation-delay: 0.95s;
  }

  .sparkle {
    position: absolute;
    bottom: 14%;
    width: 8px;
    height: 8px;
    background: #d8f4ff;
    animation: sparkle 1.1s steps(2, end) infinite;
  }

  .sparkle-1 {
    left: 24%;
    animation-delay: 0.1s;
  }

  .sparkle-2 {
    left: 55%;
    animation-delay: 0.55s;
  }

  .sparkle-3 {
    left: 78%;
    animation-delay: 0.85s;
  }

  .tree-line {
    position: absolute;
    left: 0;
    bottom: 42%;
    width: 100%;
    height: 19%;
    z-index: 2;
    pointer-events: none;
  }

  .tree {
    position: absolute;
    bottom: 0;
    width: 4.4%;
    height: 42%;
    background: #3f2f28;
    border: 3px solid #2a1e1a;
