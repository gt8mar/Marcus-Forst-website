---
import Layout from '../components/layout.astro';
---

<Layout
  title="Where In The World Is Marcus"
  description="Now broadcasting from Columbus, Mississippi."
  currentPath="/where-in-the-world-is-marcus"
>
  <main class="pixel-page">
    <h1>Where in the world is Marcus?</h1>
    <p class="location" aria-label="Current location">Columbus, Mississippi</p>
    <p class="tagline">Pixel steamboat report from the Tombigbee</p>
    <div class="pixel-scene" aria-hidden="true">
      <div class="pixel-sun"></div>
      <div class="pixel-moon"></div>
      <div class="pixel-city"></div>
      <div class="riverfront-strip">
        <div class="shop shop-jb">
          <span class="shop-sign">J. Broussard's</span>
        </div>
        <div class="shop shop-arepas">
          <span class="shop-sign">Arepas Coffee + Bar</span>
        </div>
        <div class="shop shop-harveys">
          <span class="shop-sign">Harvey's</span>
        </div>
        <div class="shop shop-munson">
          <span class="shop-sign">Munson &amp; Brothers Pizza</span>
        </div>
      </div>
      <div class="street-band"></div>
      <div class="grass-band"></div>
      <div class="tree-line">
        <div class="tree tree-1"></div>
        <div class="tree tree-2"></div>
        <div class="tree tree-3"></div>
        <div class="tree tree-4"></div>
        <div class="tree tree-5"></div>
      </div>
      <div class="riverwalk-path"></div>
      <div class="pixel-river">
        <div class="boat">
          <span class="smoke smoke-1"></span>
          <span class="smoke smoke-2"></span>
          <span class="smoke smoke-3"></span>
          <span class="wheel"></span>
        </div>
        <div class="sparkle sparkle-1"></div>
        <div class="sparkle sparkle-2"></div>
        <div class="sparkle sparkle-3"></div>
      </div>
    </div>
    <p class="back-home">
      <a href="/">Take me back home</a>
    </p>
    <p class="archive-link">
      <a href="/archive/where-in-the-world-is-marcus-oklahoma">View Oklahoma archive</a>
    </p>
  </main>
</Layout>

<style>
  .pixel-page {
    --ink: #f6f7ff;
    --sky-top: #ffb45f;
    --sky-mid: #f06b6b;
    --sky-bottom: #61458f;
    --river-dark: #12345b;
    --river-mid: #1b4f7e;
    --river-light: #3d9ad1;
    --pixel-shadow: #1a1233;
    width: 100%;
    min-height: calc(100vh - 3.5rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1rem;
    padding: 2rem 1rem 5rem;
    background: linear-gradient(
      180deg,
      var(--sky-top) 0%,
      var(--sky-mid) 38%,
      var(--sky-bottom) 62%,
      #11102d 100%
    );
    color: var(--ink);
    font-family: 'Courier New', Courier, monospace;
    image-rendering: pixelated;
  }

  .pixel-page h1 {
    margin: 0;
    font-size: clamp(1.3rem, 3.2vw, 2.2rem);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-shadow: 3px 3px 0 var(--pixel-shadow);
  }

  .location {
    margin: 0;
    font-size: clamp(1.9rem, 6.5vw, 3.8rem);
    font-weight: 700;
    color: #84f8ff;
    text-shadow: 4px 4px 0 #18355e;
    line-height: 1.08;
  }

  .tagline {
    margin: 0;
    font-size: clamp(0.85rem, 2vw, 1rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #ffe8b3;
  }

  .pixel-scene {
    --sun-x: 82%;
    --sun-y: 12%;
    --moon-x: 14%;
    --moon-y: 68%;
    width: min(92vw, 760px);
    aspect-ratio: 16 / 9;
    border: 5px solid #0d0e2e;
    box-shadow:
      0 0 0 5px #f8d65a,
      10px 10px 0 #0d0e2e;
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(
        180deg,
        rgba(255, 201, 109, 0.7) 0%,
        rgba(240, 107, 107, 0.4) 40%,
        rgba(14, 24, 61, 0) 64%
      ),
      repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.03) 0 4px, transparent 4px 8px),
      linear-gradient(180deg, #8a5f85 0%, #402f69 64%, #111832 100%);
  }

  .pixel-sun {
    position: absolute;
    top: var(--sun-y);
    left: var(--sun-x);
    width: 16%;
    aspect-ratio: 1;
    background: #ffef95;
    box-shadow:
      0 0 0 6px #ff9a64,
      0 0 0 12px rgba(255, 154, 100, 0.45);
    animation: pulse-sun 2.8s steps(2, end) infinite;
    transform: translate(-50%, -50%);
    z-index: 1;
  }

  .pixel-moon {
    position: absolute;
    top: var(--moon-y);
    left: var(--moon-x);
    width: 12%;
    aspect-ratio: 1;
    background: #dff3ff;
    box-shadow:
      0 0 0 5px #8ec0e3,
      0 0 0 10px rgba(142, 192, 227, 0.32);
    transform: translate(-50%, -50%);
    opacity: 0;
    z-index: 1;
  }

  .pixel-moon::before {
    content: '';
    position: absolute;
    width: 34%;
    aspect-ratio: 1;
    top: 26%;
    left: 22%;
    background: #acd3eb;
    opacity: 0.8;
  }

  .pixel-moon::after {
    content: '';
    position: absolute;
    width: 20%;
    aspect-ratio: 1;
    top: 56%;
    left: 58%;
    background: #acd3eb;
    opacity: 0.75;
  }

  .pixel-city {
    position: absolute;
    bottom: 36%;
    left: 0;
    width: 100%;
    height: 24%;
    background:
      linear-gradient(90deg, transparent 0 3%, #2f264f 3% 8%, transparent 8% 10%, #201a3f 10% 15%, transparent 15% 18%, #362d5b 18% 23%, transparent 23% 26%, #271f49 26% 33%, transparent 33% 35%, #33295a 35% 40%, transparent 40% 43%, #241d47 43% 48%, transparent 48% 52%, #362d5b 52% 57%, transparent 57% 61%, #251e48 61% 67%, transparent 67% 70%, #2d2452 70% 76%, transparent 76% 80%, #201a3f 80% 86%, transparent 86% 100%);
    box-shadow: 0 -4px 0 #ffcc7a;
  }

  .riverfront-strip {
    position: absolute;
    left: 0;
    bottom: 42%;
    width: 100%;
    height: 21%;
    display: grid;
    grid-template-columns: 1.05fr 1fr 0.95fr 1.1fr;
    gap: 4px;
    padding: 0 8px;
    z-index: 3;
  }

  .shop {
    position: relative;
    align-self: end;
    height: 100%;
    background:
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.06) 0 3px,
        transparent 3px 8px
      ),
      repeating-linear-gradient(
        180deg,
        #875049 0 6px,
        #7a453f 6px 12px
      );
    border: 3px solid #2c1a32;
    box-shadow:
      inset 0 -10px 0 #e5c898,
      inset 0 -22px 0 #6f2e41,
      inset 0 7px 0 #c38f6d,
      0 -4px 0 #2c1a32;
  }

  .shop::before {
    content: '';
    position: absolute;
    left: 8%;
    right: 8%;
    top: 24%;
    height: 36%;
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.45), rgba(255, 255, 255, 0.1)),
      repeating-linear-gradient(
        90deg,
        #a7d0ef 0 8px,
        #7caed6 8px 16px
      );
    border: 3px solid #2c1a32;
  }

  .shop::after {
    content: '';
    position: absolute;
    left: 20%;
    right: 20%;
    bottom: 0;
    height: 30%;
    background: #533147;
    border-left: 3px solid #2c1a32;
    border-right: 3px solid #2c1a32;
  }

  .shop-sign {
    position: absolute;
    left: 8%;
    right: 8%;
    top: -14px;
    background: #1a1233;
    border: 3px solid #f7d66f;
    color: #ffefbf;
    font-size: clamp(0.46rem, 1vw, 0.6rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0.02em;
    padding: 2px 3px;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    box-shadow: 2px 2px 0 #2c1a32;
  }

  .shop-jb {
    background:
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.06) 0 3px,
        transparent 3px 8px
      ),
      repeating-linear-gradient(
        180deg,
        #8f4f42 0 6px,
        #784133 6px 12px
      );
  }

  .shop-jb .shop-sign {
    border-color: #f6d791;
    color: #fdf2ce;
  }

  .shop-arepas {
    height: 90%;
    background:
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.06) 0 3px,
        transparent 3px 8px
      ),
      repeating-linear-gradient(
        180deg,
        #7f4e5f 0 6px,
        #6b3e4f 6px 12px
      );
  }

  .shop-arepas .shop-sign {
    border-color: #77e3ff;
    color: #dbf8ff;
  }

  .shop-harveys {
    height: 100%;
    background:
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.06) 0 3px,
        transparent 3px 8px
      ),
      repeating-linear-gradient(
        180deg,
        #6e495f 0 6px,
        #5a3a50 6px 12px
      );
  }

  .shop-harveys .shop-sign {
    border-color: #ffb16b;
    color: #ffe0bd;
  }

  .shop-munson {
    height: 96%;
    background:
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.06) 0 3px,
        transparent 3px 8px
      ),
      repeating-linear-gradient(
        180deg,
        #82523e 0 6px,
        #6f4433 6px 12px
      );
  }

  .shop-munson .shop-sign {
    border-color: #ffd66e;
    color: #fff2bf;
  }

  .pixel-river {
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 30%;
    background:
      repeating-linear-gradient(
        180deg,
        var(--river-light) 0 8px,
        var(--river-mid) 8px 16px,
        var(--river-dark) 16px 24px
      );
    overflow: hidden;
  }

  .street-band {
    position: absolute;
    left: 0;
    bottom: 38%;
    width: 100%;
    height: 4%;
    z-index: 2;
    background:
      repeating-linear-gradient(
        90deg,
        #34313a 0 20px,
        #3f3b47 20px 40px
      );
    box-shadow:
      inset 0 3px 0 #7e6d58,
      inset 0 -3px 0 #201c29;
  }

  .grass-band {
    position: absolute;
    left: 0;
    bottom: 34%;
    width: 100%;
    height: 4%;
    z-index: 2;
    background:
      repeating-linear-gradient(
        90deg,
        #4e8f4a 0 12px,
        #3c7b3f 12px 24px
      );
    box-shadow:
      inset 0 2px 0 rgba(203, 240, 144, 0.45),
      inset 0 -2px 0 #2b5c33;
  }

  .riverwalk-path {
    position: absolute;
    left: 0;
    bottom: 30%;
    width: 100%;
    height: 4%;
    z-index: 2;
    background:
      repeating-linear-gradient(
        90deg,
        #cab08a 0 16px,
        #b69973 16px 32px
      );
    box-shadow:
      inset 0 2px 0 rgba(255, 248, 224, 0.45),
      inset 0 -2px 0 #7d6142;
  }

  .pixel-river::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        90deg,
        transparent 0 20px,
        rgba(255, 255, 255, 0.12) 20px 24px,
        transparent 24px 38px
      );
    animation: water-shift 1.8s steps(4, end) infinite;
  }

  .boat {
    position: absolute;
    bottom: 26%;
    left: -22%;
    width: 21%;
    aspect-ratio: 3 / 2;
    background:
      linear-gradient(180deg, #fff9e6 0 38%, transparent 38% 100%),
      linear-gradient(180deg, transparent 0 58%, #b02f40 58% 74%, #51163a 74% 100%);
    box-shadow: 0 0 0 4px #2a123d;
    animation: boat-sail 10s linear infinite;
    z-index: 2;
  }

  .boat::before {
    content: '';
    position: absolute;
    top: -26%;
    left: 18%;
    width: 18%;
    height: 22%;
    background: #fff4b2;
    box-shadow:
      0 0 0 3px #2a123d,
      130% 22% 0 0 #fff4b2,
      130% 22% 0 3px #2a123d;
  }

  .boat::after {
    content: '';
    position: absolute;
    right: -7%;
    bottom: 12%;
    width: 9%;
    height: 46%;
    background:
      repeating-linear-gradient(180deg, #ffe7a1 0 6px, #f39c58 6px 12px);
    border: 3px solid #2a123d;
  }

  .wheel {
    position: absolute;
    bottom: -14%;
    left: 44%;
    width: 18%;
    aspect-ratio: 1;
    border: 4px solid #2a123d;
    background:
      conic-gradient(from 0deg, #ffe7a1 0 25%, #d85757 25% 50%, #ffe7a1 50% 75%, #d85757 75% 100%);
    animation: wheel-spin 0.9s steps(4, end) infinite;
  }

  .smoke {
    position: absolute;
    top: -34%;
    width: 10%;
    aspect-ratio: 1;
    background: #efe8ff;
    opacity: 0;
    animation: puff 1.7s steps(3, end) infinite;
  }

  .smoke-1 {
    left: 26%;
    animation-delay: 0.2s;
  }

  .smoke-2 {
    left: 42%;
    animation-delay: 0.6s;
  }

  .smoke-3 {
    left: 58%;
    animation-delay: 0.95s;
  }

  .sparkle {
    position: absolute;
    bottom: 14%;
    width: 8px;
    height: 8px;
    background: #d8f4ff;
    animation: sparkle 1.1s steps(2, end) infinite;
  }

  .sparkle-1 {
    left: 24%;
    animation-delay: 0.1s;
  }

  .sparkle-2 {
    left: 55%;
    animation-delay: 0.55s;
  }

  .sparkle-3 {
    left: 78%;
    animation-delay: 0.85s;
  }

  .tree-line {
    position: absolute;
    left: 0;
    bottom: 37.5%;
    width: 100%;
    height: 7%;
    z-index: 4;
    pointer-events: none;
  }

  .tree {
    position: absolute;
    bottom: 0;
    width: 8%;
    height: 100%;
    background: #2f5e2f;
    border: 3px solid #1f3926;
    box-shadow:
      inset 0 -4px 0 #233f2b,
      0 2px 0 #172c1d;
  }

  .tree::before {
    content: '';
    position: absolute;
    bottom: 75%;
    left: -35%;
    width: 170%;
    height: 90%;
    background:
      repeating-linear-gradient(
        90deg,
        #3e7a3b 0 8px,
        #336833 8px 16px
      );
    border: 3px solid #1f3926;
    box-shadow: inset 0 3px 0 rgba(197, 235, 157, 0.4);
  }

  .tree::after {
    content: '';
    position: absolute;
    bottom: 136%;
    left: -15%;
    width: 130%;
    height: 58%;
    background:
      repeating-linear-gradient(
        90deg,
        #3a7037 0 6px,
        #315f31 6px 12px
      );
    border: 3px solid #1f3926;
  }

  .tree-1 {
    left: 4%;
    height: 78%;
  }

  .tree-2 {
    left: 24%;
    height: 94%;
  }

  .tree-3 {
    left: 46%;
    height: 84%;
  }

  .tree-4 {
    left: 67%;
    height: 100%;
  }

  .tree-5 {
    left: 86%;
    height: 80%;
  }

  .pixel-scene.is-night {
    background:
      linear-gradient(
        180deg,
        rgba(126, 123, 186, 0.34) 0%,
        rgba(53, 49, 108, 0.4) 42%,
        rgba(8, 12, 28, 0.42) 100%
      ),
      repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.03) 0 4px, transparent 4px 8px),
      linear-gradient(180deg, #3e3d72 0%, #211f4e 58%, #091122 100%);
  }

  .pixel-scene.is-night .pixel-sun {
    opacity: 0.2;
  }

  .pixel-scene.is-night .pixel-moon {
    opacity: 1;
  }

  .back-home {
    margin-top: auto;
    margin-bottom: 0;
  }

  .back-home a,
  .back-home a:visited {
    color: #ffe28f !important;
    font-size: 1rem;
    text-decoration: underline !important;
    text-decoration-color: currentColor !important;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .back-home a:hover,
  .back-home a:focus {
    color: #84f8ff !important;
  }

  .archive-link {
    margin: 0.2rem 0 0;
    font-size: 0.85rem;
  }

  .archive-link a,
  .archive-link a:visited {
    color: #f6f7ff !important;
    text-decoration: underline !important;
    text-decoration-color: currentColor !important;
  }

  .archive-link a:hover,
  .archive-link a:focus {
    color: #ffe28f !important;
  }

  @keyframes boat-sail {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(640%);
    }
  }

  @keyframes wheel-spin {
    to {
      transform: rotate(1turn);
    }
  }

  @keyframes puff {
    0% {
      opacity: 0;
      transform: translateY(0) scale(0.6);
    }
    30% {
      opacity: 0.8;
    }
    100% {
      opacity: 0;
      transform: translateY(-34px) translateX(8px) scale(1.1);
    }
  }

  @keyframes water-shift {
    to {
      transform: translateX(24px);
    }
  }

  @keyframes sparkle {
    50% {
      opacity: 0.2;
      transform: translateY(-4px);
    }
  }

  @keyframes pulse-sun {
    50% {
      transform: translateY(2px);
    }
  }

  @media (max-width: 640px) {
    .pixel-scene {
      box-shadow:
        0 0 0 4px #f8d65a,
        6px 6px 0 #0d0e2e;
    }

    .tagline {
      max-width: 26ch;
    }

    .riverfront-strip {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr;
      height: 28%;
      bottom: 42%;
      gap: 3px;
      padding: 0 6px;
    }

    .shop,
    .shop-arepas,
    .shop-harveys,
    .shop-munson {
      height: auto;
    }

    .shop-sign {
      font-size: clamp(0.38rem, 1.8vw, 0.48rem);
    }

    .tree-line {
      height: 6.2%;
      bottom: 37.7%;
    }

    .street-band,
    .grass-band,
    .riverwalk-path {
      height: 3.5%;
    }

    .street-band {
      bottom: 38.5%;
    }

    .grass-band {
      bottom: 35%;
    }

    .riverwalk-path {
      bottom: 31.5%;
    }

    .pixel-river {
      height: 31.5%;
    }
  }
</style>

<script>
  const scene = document.querySelector('.pixel-scene');

  const toParts = (date) =>
    new Intl.DateTimeFormat('en-US', {
      timeZone: 'America/Chicago',
      hour12: false,
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit'
    }).formatToParts(date);

  const clockSeconds = () => {
    const parts = toParts(new Date());
    const get = (type) => Number(parts.find((p) => p.type === type)?.value || 0);
    return get('hour') * 3600 + get('minute') * 60 + get('second');
  };

  const updateSky = () => {
    if (!scene) return;
    const seconds = clockSeconds();
    const dayStart = 6 * 3600;
    const dayEnd = 18 * 3600;
    const isDay = seconds >= dayStart && seconds < dayEnd;
    scene.classList.toggle('is-night', !isDay);

    if (isDay) {
      const progress = (seconds - dayStart) / (dayEnd - dayStart);
      const sunX = 6 + 80 * progress;
      const sunY = 62 - 52 * Math.sin(progress * Math.PI);
      scene.style.setProperty('--sun-x', `${sunX}%`);
      scene.style.setProperty('--sun-y', `${sunY}%`);
      return;
    }

    const nightSeconds = seconds >= dayEnd ? seconds - dayEnd : seconds + 6 * 3600;
    const nightProgress = nightSeconds / (12 * 3600);
    const moonX = 12 + 74 * nightProgress;
    const moonY = 74 - 54 * nightProgress;
    scene.style.setProperty('--moon-x', `${moonX}%`);
    scene.style.setProperty('--moon-y', `${moonY}%`);
  };

  updateSky();
  setInterval(updateSky, 60 * 1000);
</script>
